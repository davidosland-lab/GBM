# Required by NCBI E-utilities. Use a real contact email for API requests.
NCBI_EMAIL=your.email@example.com

# Optional. Raises NCBI rate limit from roughly 3 requests/sec to 10 requests/sec.
NCBI_API_KEY=

# Optional. Tool name sent to NCBI.
NCBI_TOOL=gbm-ai-platform

# Optional unless loading or inspecting a live Neo4j knowledge graph.
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=
